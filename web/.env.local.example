# ─── Backend API (FastAPI) ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Stripe (publishable key, optional in dev) ────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── NextAuth core ────────────────────────────────────────────────────────
# Must match the URL you visit the app at. Use https in prod.
NEXTAUTH_URL=http://localhost:3000

# Generate with:  openssl rand -base64 32
# (must be set for sign-in to work; required in production)
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# ─── Google OAuth ─────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → "OAuth client ID"
#   - Application type: Web application
#   - Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Apple "Sign in with Apple" ───────────────────────────────────────────
# APPLE_CLIENT_ID = your Services ID, e.g. ai.otune.web
# APPLE_CLIENT_SECRET = the JWT you generate from your Apple .p8 private key.
# See docs/auth-setup.md for the full step-by-step.
#   - Authorized redirect URI: http://localhost:3000/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
