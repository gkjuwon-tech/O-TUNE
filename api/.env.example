# ─── Mode ────────────────────────────────────────────────────────────────
OTUNE_ENV=dev
OTUNE_MODE=dev                  # dev = local training + local FS; prod = RunPod + S3
OTUNE_DATABASE_URL=postgresql+psycopg://otune:otune@localhost:5432/otune
OTUNE_FRONTEND_URL=http://localhost:3000
OTUNE_API_URL=http://localhost:8000
OTUNE_DATA_DIR=./data           # used when OTUNE_MODE=dev

# ─── Anthropic (dataset gen + grader) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OTUNE_CLAUDE_MODEL=claude-sonnet-4-5

# ─── OpenAI (optional fallback grader) ───────────────────────────────────
OPENAI_API_KEY=
OTUNE_OPENAI_MODEL=gpt-4o

# ─── Tavily (benchmark agent web search) ─────────────────────────────────
# Google Programmable Search dropped the "Search the entire web" option, so we
# moved the benchmark agent to Tavily. Free tier: 1,000 credits / month.
TAVILY_API_KEY=tvly-...

# ─── HuggingFace (pull base model weights) ───────────────────────────────
HUGGINGFACE_TOKEN=hf_...

# ─── Stripe (test mode for dev) ──────────────────────────────────────────
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Local training (dev mode) ───────────────────────────────────────────
OTUNE_DEV_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
OTUNE_DEV_DATASET_ROWS=100
OTUNE_DEV_TRAIN_EPOCHS=2
OTUNE_DEV_LR=2.0e-4
OTUNE_DEV_LORA_R=8

# ─── Skipped in dev: RunPod, AWS S3 ──────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_GPU_TYPE_70B=NVIDIA H100 80GB HBM3
RUNPOD_GPU_TYPE_8B=NVIDIA A100 80GB
OTUNE_S3_BUCKET=
OTUNE_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
